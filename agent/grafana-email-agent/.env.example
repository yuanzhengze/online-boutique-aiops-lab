# ============================================
# Grafana 智能分析与邮件通知 Agent 配置
# ============================================
# 复制此文件为 .env 并填写真实值
# .env 文件已在 .gitignore 中排除，不会被提交

# ============================================
# 数据源（二选一）
# ============================================

# 方式一：Prometheus 直接查询（推荐）
# 服务器上运行时（SSH 到服务器执行 Agent）：
#   PROMETHEUS_URL=http://172.17.0.7:32090
# 本机运行时（需先建立 SSH 隧道 ssh -L 9090:172.17.0.7:32090）：
#   PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_URL=http://172.17.0.7:32090

# 方式二：Grafana API（如果 Prometheus 不可用时使用）
# GRAFANA_URL=http://172.17.0.7:32000
# GRAFANA_API_KEY=replace-with-grafana-api-key

# ============================================
# 查询设置
# ============================================
QUERY_RANGE_MINUTES=30
ERROR_RATE_THRESHOLD=0.05
LATENCY_THRESHOLD_MS=1000
CPU_THRESHOLD_PERCENT=80
MEMORY_THRESHOLD_PERCENT=80

# ============================================
# DeepSeek AI 分析（可选，留空则使用规则分析）
# ============================================
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-v4-flash

# ============================================
# 邮件设置
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=replace-with-app-password
MAIL_FROM=your-email@example.com
MAIL_TO=member1@example.com,member2@example.com

# ============================================
# 常用 SMTP 配置参考
# ============================================
# QQ邮箱: SMTP_HOST=smtp.qq.com, SMTP_PORT=587
# 163邮箱: SMTP_HOST=smtp.163.com, SMTP_PORT=465
# Gmail:  SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Outlook: SMTP_HOST=smtp.office365.com, SMTP_PORT=587
# 注意：QQ/163 需要开启 SMTP 服务并获取授权码
